# ─── Database ────────────────────────────────────────────────────────────────
# Local dev: port 5433 (Docker). Production: AWS RDS endpoint.
DATABASE_URL=postgresql://olifant:olifant_dev@localhost:5433/olifant

# ─── ClickHouse ──────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://olifant:olifant_dev@localhost:8123/olifant

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Environment ─────────────────────────────────────────────────────────────
# development | production
NODE_ENV=development

# ─── Next.js → API proxy ─────────────────────────────────────────────────────
# Local dev: http://localhost:3001. Production: internal ALB URL (never public).
API_URL=http://localhost:3001

# ─── Amazon Advertising API ──────────────────────────────────────────────────
# From: advertising.amazon.com → Manage applications
ADS_CLIENT_ID=
ADS_CLIENT_SECRET=
# Per-client refresh token obtained via OAuth consent flow
ADS_REFRESH_TOKEN=
# From: GET /v2/profiles — the profile ID for the advertiser account
ADS_PROFILE_ID=

# ─── AWS ─────────────────────────────────────────────────────────────────────
# Use IAM roles in production (ECS task definition) — never hardcode these.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Anthropic (AI Co-pilot) ──────────────────────────────────────────────────
# Server-side only — never exposed to the frontend. Get a key from console.anthropic.com
ANTHROPIC_API_KEY=
